{
	"name": "n8n-nodes-subspace",
	"version": "0.1.1",
	"description": "n8n community node for Subspace — operational company intelligence from DNS, HTTP, and ATS forensics. 88+ fields per domain with zero LinkedIn dependency.",
	"license": "MIT",
	"homepage": "https://www.thesubspace.io",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"subspace",
		"company-intelligence",
		"company-enrichment",
		"ghost-job-detection",
		"operational-signals",
		"revops",
		"sales-enrichment"
	],
	"author": {
		"name": "Subspace",
		"email": "dev@thesubspace.io",
		"url": "https://www.thesubspace.io"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/thesubspaceio/n8n-nodes-subspace.git"
	},
	"bugs": {
		"url": "https://github.com/thesubspaceio/n8n-nodes-subspace/issues"
	},
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/SubspaceApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Subspace/Subspace.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.39.4",
		"prettier": "3.8.1",
		"release-it": "19.2.4",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
